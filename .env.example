# Copy to `.env` and fill in to enable the Claude-powered (GenAI) reasoning core.
# Without a key, MatchDay Ops still runs its deterministic, grounded offline
# engine — no secret is ever required to use the app.

# Your Anthropic API key. Keep this secret; never commit the real .env file.
ANTHROPIC_API_KEY=

# Optional: override the default model (Claude Opus 4.8).
MATCHDAY_MODEL=claude-opus-4-8
